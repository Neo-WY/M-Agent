%% M-Agent 整体运行流程图
%% 渲染方式见 docs/m_agent_pipeline.md
flowchart TB
    subgraph Client["客户端 (M-Agent-UI / Desktop / 第三方)"]
        U["用户消息<br/>(POST /v1/chat/runs)"]
        SUB["SSE 订阅<br/>(GET /v1/chat/runs/{run_id}/events<br/>GET /v1/chat/threads/{tid}/events)"]
    end

    subgraph API["API 层 (FastAPI · src/m_agent/api/chat_api_web.py)"]
        AUTH["鉴权 / 用户隔离<br/>(user_access · username::thread_id)"]
        ROUTER["路由分发<br/>(chat / dialogues / threads / schedules)"]
        SSEOUT["SSE 事件流推送"]
    end

    subgraph Runtime["服务运行时 (chat_api_runtime.ChatServiceRuntime)"]
        THREAD["线程会话状态<br/>ThreadSessionState<br/>(history_max_rounds · pending buffer)"]
        RUNCHAT["run_chat() / run_schedule_trigger()"]
        IDLEFLUSH["空闲 Flush 守护线程<br/>(idle_flush_seconds)"]
        FLUSH["flush_thread()<br/>持久化 pending rounds"]
    end

    subgraph Heartbeat["日程心跳 (schedule_heartbeat.ScheduleHeartbeatCoordinator)"]
        BEAT["beat_once() 后台循环<br/>(schedule-beat-seconds)"]
        DUE["租约到期日程"]
    end

    subgraph App["应用层 Agent (chat/simple_chat_agent.py)"]
        SMCA["SimpleMemoryChatAgent.chat()<br/>(组合 Controller + Persistence)"]
    end

    subgraph Controller["顶层控制 Agent (agents/chat_controller_agent.py)"]
        CCA["ChatControllerAgent<br/>(LangChain create_agent + ToolStrategy)"]
        SYS["拼装 system prompt<br/>(persona + 工具描述 + 运行时上下文)"]
        TOOLS["顶层工具注册表<br/>(capabilities · enabled_tools / tool_defaults)"]
        LOOP["LLM ↔ 工具调用循环<br/>(max_calls_per_turn / recursion_limit)"]
    end

    subgraph SubAgents["子 Agent / 工具 (黑盒, 不展开内部)"]
        MEM["MemoryAgent<br/>shallow_recall · deep_recall<br/>(Workspace-Mem 检索框架)"]
        SCH["ScheduleAgent<br/>schedule_manage · schedule_query"]
        MAIL["EmailAgent<br/>email_ask · email_read · email_send"]
        TIME["get_current_time"]
    end

    subgraph Persistence["记忆持久化 (chat/simple_chat_agent.ChatMemoryPersistence)"]
        DLG["写入 dialogues/<br/>(data/memory/user_*/dialogues)"]
        EPI["MemoryCore 抽取<br/>episodes / facts / entity_library"]
    end

    subgraph Storage["底层存储 (data/)"]
        FS_DLG[("dialogues/*.json")]
        FS_EPI[("episodes/*.json")]
        FS_ENT[("entity_library/*.json")]
        FS_SCH[("schedules/*.json")]
    end

    %% ---- 主请求链路 ----
    U --> AUTH --> ROUTER -->|"创建 run · 异步执行"| RUNCHAT
    SUB --> SSEOUT
    ROUTER -.事件.-> SSEOUT

    RUNCHAT -->|"读取最近历史<br/>(history_messages)"| THREAD
    RUNCHAT --> SMCA
    SMCA --> CCA
    CCA --> SYS --> LOOP
    TOOLS --> LOOP

    LOOP -->|"按需调度"| MEM
    LOOP -->|"按需调度"| SCH
    LOOP -->|"按需调度"| MAIL
    LOOP -->|"按需调度"| TIME

    MEM -->|"召回结果 / evidence"| LOOP
    SCH -->|"日程 CRUD 结果"| LOOP
    MAIL -->|"邮件结果"| LOOP
    TIME --> LOOP

    LOOP -->|"最终 answer + agent_result"| SMCA
    SMCA -->|"append round → buffer"| THREAD
    SMCA -->|"answer / 事件"| ROUTER
    ROUTER -->|"完成事件 / 最终结果"| SSEOUT --> SUB

    %% ---- 后台日程触发 ----
    BEAT --> DUE
    DUE -->|"派发到对应 thread"| RUNCHAT
    RUNCHAT -->|"source=schedule<br/>注入隐藏运行时上下文"| SMCA

    %% ---- 记忆 Flush ----
    THREAD -.空闲超时/手动.- IDLEFLUSH --> FLUSH
    ROUTER -->|"POST /memory/flush"| FLUSH
    FLUSH --> DLG --> EPI
    DLG --> FS_DLG
    EPI --> FS_EPI
    EPI --> FS_ENT
    SCH -.写入.-> FS_SCH
    BEAT -.读取.-> FS_SCH

    classDef box fill:#fafafa,stroke:#888,color:#222
    classDef hot fill:#e8f1ff,stroke:#3b6fb6,color:#1a3a6b
    classDef sub fill:#f3e8ff,stroke:#7b3fbf,color:#3b1a6b
    classDef store fill:#f0f7ee,stroke:#3a8a3a,color:#1f4d1f
    class API,Runtime,Heartbeat,App,Controller,Persistence box
    class Client hot
    class SubAgents sub
    class Storage store
